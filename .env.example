# AI provider
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.aitunnel.ru/v1
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini
IMAGE_MODEL=gpt-image-1
IMAGE_QUALITY=low

# Yandex Organization Search API
# Public organization search finds service centers and their cards.
YANDEX_MAPS_API_KEY=
YANDEX_MAPS_SEARCH_URL=https://search-maps.yandex.ru/v1/

# Exist Opt API
# Exact request mapping will be enabled after credentials and full request schemas are confirmed.
EXIST_API_BASE_URL=https://api.exist.ru/Opt
EXIST_API_TOKEN=
EXIST_API_TOKEN_HEADER=Authorization
EXIST_API_TOKEN_PREFIX=Bearer
EXIST_OFFICE_ID=

# Future vehicle data provider
VEHICLE_DATA_PROVIDER=tronk
TRONK_API_BASE_URL=
TRONK_API_KEY=
